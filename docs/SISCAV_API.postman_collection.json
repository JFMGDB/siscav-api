								{
									"key": "token",
									"value": "{{access_token}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"plate\": \"XYZ-5678\",\n    \"description\": \"Veículo atualizado\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/v1/whitelist/{{plate_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "whitelist", "{{plate_id}}"]
						},
						"description": "Atualiza os dados de uma placa existente."
					},
