							"query": [
								{
									"key": "skip",
									"value": "0",
									"description": "Número de registros a pular (paginação)"
								},
								{
									"key": "limit",
									"value": "100",
									"description": "Número máximo de registros (máximo 100)"
								}
							]
						},
