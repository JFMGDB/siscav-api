			],
			"description": "CRUD de placas em `/api/v1/whitelist/` (autenticado; não exige admin no código atual)"
		},
		{
			"name": "Access Logs - Logs de Acesso",
			"item": [
				{
					"name": "Registrar acesso (multipart)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set(\"access_log_id\", jsonData.id);",
									"    var key = jsonData.image_storage_key || \"\";",
									"    var fn = key;",
									"    var i = Math.max(key.lastIndexOf(\"/\"), key.lastIndexOf(\"\\\\\"));",
									"    if (i >= 0) fn = key.substring(i + 1);",
									"    if (fn) pm.environment.set(\"image_filename\", fn);",
									"    console.log(\"Log criado com ID: \" + jsonData.id);",
									"    console.log(\"Status: \" + jsonData.status);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "X-Device-Key",
								"value": "{{device_ingest_key}}",
								"type": "text",
								"description": "Obrigatório se DEVICE_INGEST_KEY estiver definida no servidor",
								"disabled": true
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": [],
									"description": "Arquivo de imagem do veículo (JPG, PNG, etc.)"
								},
								{
									"key": "plate",
									"value": "ABC-1234",
									"type": "text",
									"description": "String da placa detectada pelo OCR"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/api/v1/access_logs/",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "access_logs", ""]
						},
						"description": "`POST /api/v1/access_logs/` — `multipart/form-data`: campo **`plate`** (texto) + **`file`** (imagem).\n\n**Autenticação:** não usa Bearer; pode exigir **`X-Device-Key`** igual a `DEVICE_INGEST_KEY` quando esta variável está definida. Ative o header acima e defina `device_ingest_key` no ambiente Postman.\n\n**Resposta:** `AccessLogRead` — `status` `Authorized` ou `Denied` conforme whitelist. `image_storage_key` é caminho de ficheiro (útil para `GET .../images/{filename}`)."
					},
					"response": []
				},
				{
					"name": "Listar Logs de Acesso",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{access_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/access_logs/?skip=0&limit=100",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "access_logs", ""],
							"query": [
								{
									"key": "skip",
									"value": "0",
									"description": "Número de registros a pular"
								},
								{
									"key": "limit",
									"value": "100",
									"description": "Número máximo de registros (máximo 100)"
								},
								{
									"key": "plate",
									"value": "",
									"description": "Filtrar por placa (busca parcial)",
									"disabled": true
								},
								{
									"key": "status",
									"value": "",
									"description": "Filtrar por status (Authorized/Denied)",
									"disabled": true
								},
								{
									"key": "start_date",
									"value": "",
									"description": "Data inicial (ISO 8601)",
									"disabled": true
								},
								{
									"key": "end_date",
									"value": "",
									"description": "Data final (ISO 8601)",
									"disabled": true
								}
							]
						},
						"description": "`GET /api/v1/access_logs/` — JWT Bearer (qualquer utilizador autenticado; não exige admin).\n\n**Query:** `skip`, `limit` (1–100), opcionalmente `plate` (ILIKE parcial), `status` (`Authorized`|`Denied`), `start_date`, `end_date` (ISO 8601). Ordenação: mais recente primeiro."
					},
					"response": []
				},
				{
					"name": "Listar Logs - Apenas Autorizados",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{access_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/access_logs/?status=Authorized&limit=10",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "access_logs", ""],
							"query": [
								{
									"key": "status",
									"value": "Authorized"
								},
								{
									"key": "limit",
									"value": "10"
								}
							]
						},
						"description": "Exemplo: `status=Authorized` (enum `AccessStatus` na API)."
					},
					"response": []
				},
				{
					"name": "Listar Logs - Filtrar por Placa",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{access_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/access_logs/?plate=ABC1234",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "access_logs", ""],
							"query": [
								{
									"key": "plate",
									"value": "ABC1234"
								}
							]
						},
						"description": "Lista logs filtrando por placa específica."
					},
					"response": []
				},
				{
					"name": "Obter Imagem do Log",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
