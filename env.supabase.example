# .env.supabase — copie para .env.local e ajuste a senha (URL-encode caracteres especiais).
ENVIRONMENT=development

# Preferir pooler IPv4: aws-1-sa-east-1 (confira no dashboard Supabase > Connect).
# Formato: postgresql+psycopg2://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql+psycopg2://postgres.[PROJECT_REF]:[PASSWORD_URL_ENCODED]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require

SECRET_KEY=...
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60